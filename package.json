{
    "name": "archive-management",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "ready": "pnpm check && pnpm test && pnpm build",
        "dev:web": "pnpm -F @archive-management/web exec vp dev",
        "check": "pnpm -F @archive-management/frontend-core check && pnpm -F @archive-management/web check",
        "check:fix": "pnpm -F @archive-management/frontend-core check:fix && pnpm -F @archive-management/web check:fix",
        "lint": "pnpm check",
        "lint:fix": "pnpm check:fix",
        "test": "pnpm -F @archive-management/frontend-core test && pnpm -F @archive-management/web test",
        "build": "pnpm -F @archive-management/frontend-core build && pnpm -F @archive-management/web build",
        "prepare": "vp config"
    },
    "dependencies": {},
    "devDependencies": {
        "vite-plus": "catalog:"
    },
    "engines": {
        "node": ">=22.12.0"
    },
    "packageManager": "pnpm@11.10.0"
}
