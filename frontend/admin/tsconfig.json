{
    "compilerOptions": {
        "lib": ["DOM", "DOM.Iterable", "ES2023"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2023",
        "types": ["node", "vite/client", "vitest/globals", "element-plus/global"]
    },
    "include": ["src", "vite.config.ts"]
}
