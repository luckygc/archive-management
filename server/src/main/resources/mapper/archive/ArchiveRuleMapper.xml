<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="github.luckygc.am.module.archive.mapper.ArchiveRuleMapper">

    <resultMap id="runtimeDefinitionResult" type="ArchiveRuntimeDefinition" autoMapping="true">
        <result property="conditionJson" column="condition_json"
                typeHandler="github.luckygc.am.infrastructure.mybatis.JsonObjectMapTypeHandler"/>
    </resultMap>

    <select id="listExecutableRuntimeDefinitions" resultMap="runtimeDefinitionResult">
        select definition.id,
               definition.scheme_version_id,
               definition.definition_kind,
               definition.definition_code,
               definition.definition_name,
               definition.trigger_point,
               definition.scope_fonds_code,
               definition.scope_category_code,
               definition.scope_archive_level,
               definition.priority,
               definition.condition_json,
               definition.constraint_action,
               definition.constraint_message,
               definition.status,
               definition.enabled,
               definition.field_catalog_signature,
               definition.published_by,
               definition.published_at,
               definition.version,
               definition.created_by,
               definition.created_at,
               definition.updated_by,
               definition.updated_at
        from am_archive_runtime_definition definition
        where definition.deleted_flag = false
          and definition.scheme_version_id = #{criteria.schemeVersionId}
          and definition.trigger_point = #{criteria.triggerPoint}
          and definition.status = 'PUBLISHED'
          and definition.enabled = true
          and (definition.scope_fonds_code is null
               or definition.scope_fonds_code = #{criteria.fondsCode})
          and (definition.scope_category_code is null
               or definition.scope_category_code = #{criteria.categoryCode})
          and (definition.scope_archive_level is null
               or definition.scope_archive_level = #{criteria.archiveLevel})
        order by definition.priority, definition.definition_code, definition.id
    </select>

    <select id="listRuntimeTraces" resultType="map">
        select trace.id,
               trace.scheme_version_id,
               trace.trigger_point,
               trace.object_type_code,
               trace.object_id,
               trace.definition_id,
               trace.definition_code,
               trace.definition_kind,
               trace.matched_flag,
               trace.blocking_flag,
               trace.action_json,
               trace.message,
               trace.severity,
               trace.skipped_reason,
               trace.created_by,
               trace.created_at
        from am_archive_runtime_trace trace
        left join am_archive_item item on item.id = trace.object_id
          and trace.object_type_code = 'ARCHIVE_ITEM'
          and item.deleted_flag = false
        left join am_archive_volume volume on volume.id = trace.object_id
          and trace.object_type_code = 'ARCHIVE_VOLUME'
          and volume.deleted_flag = false
        where 1 = 1
        <if test="criteria.schemeVersionId != null">
            and trace.scheme_version_id = #{criteria.schemeVersionId}
        </if>
        <if test="criteria.triggerPoint != null and criteria.triggerPoint != ''">
            and trace.trigger_point = #{criteria.triggerPoint}
        </if>
        <if test="criteria.objectTypeCode != null and criteria.objectTypeCode != ''">
            and trace.object_type_code = #{criteria.objectTypeCode}
        </if>
        <if test="criteria.objectId != null">
            and trace.object_id = #{criteria.objectId}
        </if>
        <if test="criteria.definitionKind != null and criteria.definitionKind != ''">
            and trace.definition_kind = #{criteria.definitionKind}
        </if>
        <if test="!criteria.allData">
            and (
              (trace.object_type_code = 'ARCHIVE_ITEM' and (
                <foreach collection="criteria.itemScopes" item="scope" separator=" or ">
                  (item.category_code = #{scope.categoryCode} and (
                    <foreach collection="scope.groups" item="group" separator=" or ">
                      (
                        <if test="group.fondsCodes != null and group.fondsCodes.size > 0">
                          item.fonds_code in
                          <foreach collection="group.fondsCodes" item="fondsCode"
                                   open="(" separator="," close=")">#{fondsCode}</foreach>
                        </if>
                        <if test="group.securityLevelIds != null and group.securityLevelIds.size > 0">
                          <if test="group.fondsCodes != null and group.fondsCodes.size > 0">and</if>
                          item.security_level_id in
                          <foreach collection="group.securityLevelIds" item="securityLevelId"
                                   open="(" separator="," close=")">#{securityLevelId}</foreach>
                        </if>
                        <if test="group.retentionPeriodIds != null and group.retentionPeriodIds.size > 0">
                          <if test="(group.fondsCodes != null and group.fondsCodes.size > 0)
                              or (group.securityLevelIds != null and group.securityLevelIds.size > 0)">and</if>
                          item.retention_period_id in
                          <foreach collection="group.retentionPeriodIds" item="retentionPeriodId"
                                   open="(" separator="," close=")">#{retentionPeriodId}</foreach>
                        </if>
                        <if test="group.conditions != null and group.conditions.size > 0">
                          <if test="(group.fondsCodes != null and group.fondsCodes.size > 0)
                              or (group.securityLevelIds != null and group.securityLevelIds.size > 0)
                              or (group.retentionPeriodIds != null and group.retentionPeriodIds.size > 0)">and</if>
                          exists (
                            select 1 from ${scope.tableName} dynamic_record
                            where dynamic_record.id = item.id and dynamic_record.deleted_flag = false
                            <foreach collection="group.conditions" item="condition">
                              and dynamic_record.${condition.columnName}
                              <choose>
                                <when test="condition.operatorName == 'EQ'">
                                  = #{condition.value}
                                </when>
                                <when test="condition.operatorName == 'IN'">
                                  in
                                  <foreach collection="condition.values" item="conditionValue"
                                           open="(" separator="," close=")">#{conditionValue}</foreach>
                                </when>
                                <when test="condition.operatorName == 'IS_NULL'">is null</when>
                                <when test="condition.operatorName == 'IS_NOT_NULL'">is not null</when>
                              </choose>
                            </foreach>
                          )
                        </if>
                        <if test="(group.fondsCodes == null or group.fondsCodes.size == 0)
                            and (group.securityLevelIds == null or group.securityLevelIds.size == 0)
                            and (group.retentionPeriodIds == null or group.retentionPeriodIds.size == 0)
                            and (group.conditions == null or group.conditions.size == 0)">true</if>
                      )
                    </foreach>
                  ))
                </foreach>
                <if test="criteria.itemScopes == null or criteria.itemScopes.size == 0">false</if>
              ))
              or (trace.object_type_code = 'ARCHIVE_VOLUME' and (
                <foreach collection="criteria.volumeScopes" item="scope" separator=" or ">
                  (volume.category_code = #{scope.categoryCode} and (
                    <foreach collection="scope.groups" item="group" separator=" or ">
                      (
                        <if test="group.fondsCodes != null and group.fondsCodes.size > 0">
                          volume.fonds_code in
                          <foreach collection="group.fondsCodes" item="fondsCode"
                                   open="(" separator="," close=")">#{fondsCode}</foreach>
                        </if>
                        <if test="group.securityLevelIds != null and group.securityLevelIds.size > 0">
                          <if test="group.fondsCodes != null and group.fondsCodes.size > 0">and</if>
                          volume.security_level_id in
                          <foreach collection="group.securityLevelIds" item="securityLevelId"
                                   open="(" separator="," close=")">#{securityLevelId}</foreach>
                        </if>
                        <if test="group.retentionPeriodIds != null and group.retentionPeriodIds.size > 0">
                          <if test="(group.fondsCodes != null and group.fondsCodes.size > 0)
                              or (group.securityLevelIds != null and group.securityLevelIds.size > 0)">and</if>
                          volume.retention_period_id in
                          <foreach collection="group.retentionPeriodIds" item="retentionPeriodId"
                                   open="(" separator="," close=")">#{retentionPeriodId}</foreach>
                        </if>
                        <if test="(group.fondsCodes == null or group.fondsCodes.size == 0)
                            and (group.securityLevelIds == null or group.securityLevelIds.size == 0)
                            and (group.retentionPeriodIds == null or group.retentionPeriodIds.size == 0)">true</if>
                      )
                    </foreach>
                  ))
                </foreach>
                <if test="criteria.volumeScopes == null or criteria.volumeScopes.size == 0">false</if>
              ))
              or (trace.object_type_code not in ('ARCHIVE_ITEM', 'ARCHIVE_VOLUME')
                  and trace.created_by = #{criteria.userId})
            )
        </if>
        <if test="criteria.page.cursorCreatedAt != null and criteria.page.cursorId != null">
          <choose>
            <when test="criteria.page.previous">
              and (trace.created_at, trace.id) &gt;
                  (#{criteria.page.cursorCreatedAt}, #{criteria.page.cursorId})
            </when>
            <otherwise>
              and (trace.created_at, trace.id) &lt;
                  (#{criteria.page.cursorCreatedAt}, #{criteria.page.cursorId})
            </otherwise>
          </choose>
        </if>
        order by trace.created_at
        <choose><when test="criteria.page.previous">asc</when><otherwise>desc</otherwise></choose>,
                 trace.id
        <choose><when test="criteria.page.previous">asc</when><otherwise>desc</otherwise></choose>
        limit #{criteria.page.rowLimit}
    </select>
</mapper>
