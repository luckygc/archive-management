{
    "compilerOptions": {
        "declaration": true,
        "lib": ["DOM", "DOM.Iterable", "ES2023"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2023",
        "types": ["vitest/globals"]
    },
    "include": ["src"]
}
