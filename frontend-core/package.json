{
    "name": "@archive-management/frontend-core",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./api": "./src/api/index.ts",
        "./authentication": "./src/authentication/index.ts",
        "./cap": "./src/cap/index.ts",
        "./types": "./src/types/index.ts"
    },
    "scripts": {
        "check": "pnpm exec vp lint src && tsc --noEmit",
